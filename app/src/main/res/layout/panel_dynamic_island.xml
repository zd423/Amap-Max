<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/panel_root"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:minHeight="48dp"
    android:orientation="horizontal"
    android:paddingLeft="10dp"
    android:paddingTop="7dp"
    android:paddingRight="12dp"
    android:paddingBottom="7dp">

    <!-- mode (hidden, used for state tracking) -->
    <TextView
        android:id="@+id/mode_text"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <!-- nav turn: icon + distance -->
    <LinearLayout
        android:id="@+id/nav_turn_box"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <ImageView
            android:id="@+id/nav_turn_icon"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:scaleType="fitCenter" />

        <TextView
            android:id="@+id/nav_turn_dist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="4dp"
            android:layout_marginRight="8dp"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- lane section -->
    <LinearLayout
        android:id="@+id/lane_section"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="6dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingLeft="3dp"
        android:paddingTop="1dp"
        android:paddingRight="3dp"
        android:paddingBottom="1dp"
        android:visibility="gone">

        <FrameLayout
            android:id="@+id/lane_bar_placeholder"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- traffic lights -->
    <LinearLayout
        android:id="@+id/light_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="left|center_vertical"
        android:orientation="horizontal"
        android:visibility="gone" />

    <!-- turn text (hidden, used for state tracking) -->
    <TextView
        android:id="@+id/turn_text"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <!-- alert text (hidden, used for state tracking) -->
    <TextView
        android:id="@+id/alert_text"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</LinearLayout>
